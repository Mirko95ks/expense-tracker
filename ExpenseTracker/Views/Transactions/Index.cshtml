@model ExpenseTracker.ViewModels.TransactionIndexViewModel

@{
    ViewData["Title"] = "Transactions";

    var startItem = Model.TotalCount == 0 ? 0 : ((Model.CurrentPage - 1) * Model.PageSize) + 1;
    var endItem = Math.Min(Model.CurrentPage * Model.PageSize, Model.TotalCount);
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">Transactions</h1>

    <div class="d-flex gap-2">
        <a asp-action="ExportToExcel"
           asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")"
           asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")"
           asp-route-type="@Model.Filter.Type"
           asp-route-categoryId="@Model.Filter.CategoryId"
           class="btn btn-outline-success">
            Export to Excel
        </a>

        <a asp-action="Create" class="btn btn-primary">
            + New Transaction
        </a>
    </div>
</div>

<div class="filter-card">
    <form method="get" asp-action="Index" class="row g-3">
        <div class="col-md-3">
            <label asp-for="Filter.FromDate" class="form-label">From Date</label>
            <input asp-for="Filter.FromDate" class="form-control" name="fromDate" />
        </div>

        <div class="col-md-3">
            <label asp-for="Filter.ToDate" class="form-label">To Date</label>
            <input asp-for="Filter.ToDate" class="form-control" name="toDate" />
        </div>

        <div class="col-md-3">
            <label asp-for="Filter.Type" class="form-label">Type</label>
            <select asp-for="Filter.Type" class="form-select" name="type" asp-items="Model.Filter.TypeOptions"></select>
        </div>

        <div class="col-md-3">
            <label asp-for="Filter.CategoryId" class="form-label">Category</label>
            <select asp-for="Filter.CategoryId" class="form-select" name="categoryId" asp-items="Model.Filter.CategoryOptions"></select>
        </div>

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Apply Filters</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Reset</a>
        </div>
    </form>
</div>

@if (Model.Transactions.Any())
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="text-muted">
            Showing @startItem-@endItem of @Model.TotalCount transactions
        </div>
    </div>

    <div class="table-responsive table-modern">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Description</th>
                    <th>Amount</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Transactions)
                {
                    <tr>
                        <td>@item.Date.ToString("dd.MM.yyyy")</td>
                        <td>
                            @if (item.Type == ExpenseTracker.Models.TransactionType.Income)
                            {
                                <span class="badge-soft-income">Income</span>
                            }
                            else
                            {
                                <span class="badge-soft-expense">Expense</span>
                            }
                        </td>
                        <td>@item.Category?.Name</td>
                        <td>@item.Description</td>
                        <td>
                            @if (item.Type == ExpenseTracker.Models.TransactionType.Income)
                            {
                                <span class="text-success fw-semibold">+ @item.Amount.ToString("N2")</span>
                            }
                            else
                            {
                                <span class="text-danger fw-semibold">- @item.Amount.ToString("N2")</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                            <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                            <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")"
                       asp-route-type="@Model.Filter.Type"
                       asp-route-categoryId="@Model.Filter.CategoryId"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")"
                           asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")"
                           asp-route-type="@Model.Filter.Type"
                           asp-route-categoryId="@Model.Filter.CategoryId"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-fromDate="@Model.Filter.FromDate?.ToString("yyyy-MM-dd")"
                       asp-route-toDate="@Model.Filter.ToDate?.ToString("yyyy-MM-dd")"
                       asp-route-type="@Model.Filter.Type"
                       asp-route-categoryId="@Model.Filter.CategoryId"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        Next
                    </a>
                </li>
            </ul>
        </nav>
    }
}
else
{
    <div class="empty-state">
        No transactions found for selected filters.
    </div>
}