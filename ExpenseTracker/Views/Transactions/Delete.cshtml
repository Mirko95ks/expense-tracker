@model ExpenseTracker.Models.Transaction

@{
    ViewData["Title"] = "Delete Transaction";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0 text-danger">Delete Transaction</h1>

    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card">
    <div class="alert alert-danger mb-4">
        Are you sure you want to delete this transaction? This action cannot be undone.
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div>
                <div class="text-muted mb-1">Date</div>
                <div class="fw-semibold">@Model.Date.ToString("dd.MM.yyyy")</div>
            </div>
        </div>

        <div class="col-md-6">
            <div>
                <div class="text-muted mb-1">Type</div>
                <div>
                    @if (Model.Type == ExpenseTracker.Models.TransactionType.Income)
                    {
                        <span class="badge-soft-income">Income</span>
                    }
                    else
                    {
                        <span class="badge-soft-expense">Expense</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div>
                <div class="text-muted mb-1">Category</div>
                <div class="fw-semibold">@Model.Category?.Name</div>
            </div>
        </div>

        <div class="col-md-6">
            <div>
                <div class="text-muted mb-1">Amount</div>
                <div>
                    @if (Model.Type == ExpenseTracker.Models.TransactionType.Income)
                    {
                        <span class="text-success fw-bold fs-5">+ @Model.Amount.ToString("N2")</span>
                    }
                    else
                    {
                        <span class="text-danger fw-bold fs-5">- @Model.Amount.ToString("N2")</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div>
                <div class="text-muted mb-1">Description</div>
                <div class="fw-semibold">
                    @(string.IsNullOrWhiteSpace(Model.Description) ? "No description" : Model.Description)
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <form asp-action="Delete" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>