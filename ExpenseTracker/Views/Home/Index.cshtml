@model ExpenseTracker.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

@if (!User.Identity!.IsAuthenticated)
{
    <div class="empty-state">
        <h1 class="display-5 fw-bold">Expense Tracker</h1>
        <p class="mt-3">Track your income and expenses in a simple and organized way.</p>
    </div>
}
else
{
    <h1 class="page-title">Dashboard</h1>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="summary-card summary-income">
                <h5>Total Income</h5>
                <h3>@Model.TotalIncome.ToString("N2")</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="summary-card summary-expense">
                <h5>Total Expenses</h5>
                <h3>@Model.TotalExpenses.ToString("N2")</h3>
            </div>
        </div>

        <div class="col-md-4">
            <div class="summary-card summary-balance">
                <h5>Balance</h5>
                <h3>@Model.Balance.ToString("N2")</h3>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <h3 class="section-title">Quick Actions</h3>

        <div class="quick-actions">
            <a asp-controller="Transactions"
               asp-action="Create"
               asp-route-type="@ExpenseTracker.Models.TransactionType.Income"
               class="quick-action-card quick-action-income">
                + Add Income
            </a>

            <a asp-controller="Transactions"
               asp-action="Create"
               asp-route-type="@ExpenseTracker.Models.TransactionType.Expense"
               class="quick-action-card quick-action-expense">
                + Add Expense
            </a>

            <a asp-controller="Transactions"
               asp-action="Index"
               class="quick-action-card quick-action-transactions">
                View Transactions
            </a>

            <a asp-controller="Reports"
               asp-action="Monthly"
               class="quick-action-card quick-action-report">
                View Monthly Report
            </a>
        </div>
    </div>

    <div class="mt-5">
        <h3 class="section-title">Latest Transactions</h3>

        @if (Model.LatestTransactions.Any())
        {
            <div class="table-responsive table-modern">
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Category</th>
                            <th>Type</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model.LatestTransactions)
                        {
                            <tr>
                                <td>@t.Date.ToString("dd.MM.yyyy")</td>
                                <td>@t.Category?.Name</td>
                                <td>
                                    @if (t.Type == ExpenseTracker.Models.TransactionType.Income)
                                    {
                                        <span class="badge-soft-income">Income</span>
                                    }
                                    else
                                    {
                                        <span class="badge-soft-expense">Expense</span>
                                    }
                                </td>
                                <td>
                                    @if (t.Type == ExpenseTracker.Models.TransactionType.Income)
                                    {
                                        <span class="text-success fw-semibold">+ @t.Amount.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger fw-semibold">- @t.Amount.ToString("N2")</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-state">
                No transactions yet.
            </div>
        }
    </div>

    <div class="mt-5">
        <h3 class="section-title">Expenses by Category</h3>

        @if (Model.ExpensesByCategory.Any())
        {
            <div class="form-card">
                <div class="row">
                    <div class="col-lg-8">
                        <canvas id="expensesChart"></canvas>
                    </div>
                </div>

                <div class="table-responsive table-modern mt-4">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Category</th>
                                <th>Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.ExpensesByCategory)
                            {
                                <tr>
                                    <td>@item.CategoryName</td>
                                    <td>@item.TotalAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state">
                No expense data available yet.
            </div>
        }
    </div>
}

@section Scripts {
    @if (User.Identity!.IsAuthenticated && Model.ExpensesByCategory.Any())
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

        <script>
            const expenseLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                        Model.ExpensesByCategory.Select(x => x.CategoryName)));

    const expenseData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.ExpensesByCategory.Select(x => x.TotalAmount)));

    const ctx = document.getElementById('expensesChart');

            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: expenseLabels,
                    datasets: [{
                        label: 'Expenses by Category',
                        data: expenseData,
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    cutout: '55%',
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        </script>
    }
}