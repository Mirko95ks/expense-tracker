@model ExpenseTracker.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0 text-danger">Delete Category</h1>

    <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
</div>

<div class="form-card">
    <div class="alert alert-danger mb-4">
        Are you sure you want to delete this category? This action cannot be undone.
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div>
                <div class="text-muted mb-1">Name</div>
                <div class="fw-semibold">@Model.Name</div>
            </div>
        </div>

        <div class="col-md-6">
            <div>
                <div class="text-muted mb-1">Type</div>
                <div>
                    @if (Model.Type == ExpenseTracker.Models.CategoryType.Income)
                    {
                        <span class="badge-soft-income">Income</span>
                    }
                    else
                    {
                        <span class="badge-soft-expense">Expense</span>
                    }
                </div>
            </div>
        </div>

        <div class="col-12">
            <div>
                <div class="text-muted mb-1">Source</div>
                <div class="fw-semibold">
                    @(Model.UserId == null ? "Default Category" : "My Category")
                </div>
            </div>
        </div>
    </div>

    <hr class="my-4" />

    <form asp-action="Delete" class="d-flex gap-2">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </form>
</div>